# =============================================================
#  BeeEVAL Local Dev with Server-Side Data (Hybrid Mode)
#
#  Usage:
#    1. Run  .\start-tunnel.ps1  in a separate window (keep it open).
#       It opens localhost:5432 / 6379 / 6333 forwarded to the server.
#    2. Copy this file to .env:
#         cp .env.hybrid.example .env
#    3. Fill in the four <...> secrets with the SAME values as the
#       server's .env (DB_PASSWORD, REDIS_PASSWORD, QDRANT_API_KEY, LLM_API_KEY).
#    4. Start local worker:
#         celery -A api.celery_app worker --pool=threads --concurrency=3 \
#                -Q video_analysis --loglevel=info
#
#  ALL host addresses are localhost because the SSH tunnel transparently
#  forwards them to the server's 127.0.0.1-bound docker services.
# =============================================================

# ===== PostgreSQL (via SSH tunnel -> server 127.0.0.1:5432) =====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=beeeval
DB_USER=postgres
DB_PASSWORD=<SAME_AS_SERVER_DB_PASSWORD>

# ===== Redis / Celery (via SSH tunnel -> server 127.0.0.1:6379) =====
REDIS_URL=redis://:<SAME_AS_SERVER_REDIS_PASSWORD>@localhost:6379/0
CELERY_BROKER_URL=redis://:<SAME_AS_SERVER_REDIS_PASSWORD>@localhost:6379/0
USE_CELERY=true

# ===== Qdrant (via SSH tunnel -> server 127.0.0.1:6333) =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=beeeval
QDRANT_API_KEY=<SAME_AS_SERVER_QDRANT_API_KEY>

# ===== LLM (direct from local machine, same as before) =====
LLM_API_KEY=<YOUR_LLM_KEY>
LLM_BASE_URL=https://ai.juguang.chat/v1/chat/completions
LLM_MODEL=[1刀/次]gemini-3-pro-preview-think

# ===== Moonshine ASR (local) =====
MOONSHINE_MODEL_PATH=C:/Users/cloud/AppData/Local/moonshine_voice/moonshine_voice/Cache/download.moonshine.ai/model/base-zh/quantized/base-zh
MOONSHINE_MODEL_ARCH=1

# ===== NAS (direct, same as before) =====
NAS_URL=http://114.215.186.130:8900
NAS_TOKEN=<YOUR_NAS_TOKEN>
NAS_VIDEO_ROOT=/volume1/beeeval/BeeEval测试视频

# ===== Embedding Model (local file path) =====
EMBEDDING_MODEL_PATH=D:/data/project_IntelliJ/BeeEVAL/model/bge-base-zh-v1.5
