# Supabase 数据库配置
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# LLM API 配置
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://ai.juguang.chat/v1/chat/completions
LLM_MODEL=gemini-3-pro-preview-thinking

# Dr.bee 调试台候选模型（每个模型独立 base_url + api_key + name）
# 任何一个模型 BASE_URL / API_KEY / NAME 留空，前端下拉里就不会出现。
LLM_MODEL_DEFAULT_LABEL=Gemini 3 Pro (default)
LLM_MODEL_DEFAULT_BASE_URL=https://ai.juguang.chat/v1
LLM_MODEL_DEFAULT_API_KEY=your_api_key
LLM_MODEL_DEFAULT_NAME=gemini-3-pro-preview-thinking

LLM_MODEL_MIMO_LABEL=Xiaomi MiMo v2.5
LLM_MODEL_MIMO_BASE_URL=
LLM_MODEL_MIMO_API_KEY=
LLM_MODEL_MIMO_NAME=

LLM_MODEL_MINIMAX_LABEL=MiniMax v2.7
LLM_MODEL_MINIMAX_BASE_URL=
LLM_MODEL_MINIMAX_API_KEY=
LLM_MODEL_MINIMAX_NAME=

LLM_MODEL_KIMI_LABEL=Kimi K2.5
LLM_MODEL_KIMI_BASE_URL=
LLM_MODEL_KIMI_API_KEY=
LLM_MODEL_KIMI_NAME=

# Moonshine ASR 模型配置
# 使用 download_moonshine_model.py 下载模型后填写路径
# 示例：C:/Users/YourName/AppData/Local/moonshine_voice/moonshine_voice/Cache/...
MOONSHINE_MODEL_PATH=
# 模型架构：0=Tiny, 1=Small (推荐), 2=Medium
MOONSHINE_MODEL_ARCH=1
