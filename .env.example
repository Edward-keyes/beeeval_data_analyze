# Supabase 数据库配置
SUPABASE_URL=your_supabase_url
SUPABASE_KEY=your_supabase_key

# LLM API 配置
LLM_API_KEY=your_api_key
LLM_BASE_URL=https://ai.juguang.chat/v1/chat/completions
LLM_MODEL=gemini-3-pro-preview-thinking

# Moonshine ASR 模型配置
# 使用 download_moonshine_model.py 下载模型后填写路径
# 示例：C:/Users/YourName/AppData/Local/moonshine_voice/moonshine_voice/Cache/...
MOONSHINE_MODEL_PATH=
# 模型架构：0=Tiny, 1=Small (推荐), 2=Medium
MOONSHINE_MODEL_ARCH=1
