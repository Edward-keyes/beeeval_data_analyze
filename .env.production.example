# =============================================================
#  BeeEVAL Server .env template (copy to .env.production before deploy)
#
#  !!! Replace every <REPLACE_ME_*> placeholder with a real value. !!!
#  Variables used by docker-compose.production.yml for ${VAR}
#  interpolation MUST be declared at the TOP LEVEL of this file.
# =============================================================

# ===== PostgreSQL =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=beeeval
DB_USER=postgres
# Strong random string, e.g. `openssl rand -base64 24`
DB_PASSWORD=<REPLACE_ME_DB_PASSWORD>

# ===== Redis =====
# Compose builds REDIS_URL / CELERY_BROKER_URL as redis://:${REDIS_PASSWORD}@redis:6379/0
# so this value MUST be set. Pick another strong random string.
REDIS_PASSWORD=<REPLACE_ME_REDIS_PASSWORD>

# ===== Qdrant =====
# Compose injects QDRANT__SERVICE__API_KEY into the qdrant container.
# API / Worker / local dev clients must pass the same value via QDRANT_API_KEY.
QDRANT_API_KEY=<REPLACE_ME_QDRANT_API_KEY>
QDRANT_COLLECTION=beeeval

# ===== Celery =====
USE_CELERY=true

# ===== LLM =====
LLM_API_KEY=<REPLACE_ME_LLM_API_KEY>
LLM_BASE_URL=https://ai.juguang.chat/v1/chat/completions
LLM_MODEL=<REPLACE_ME_LLM_MODEL>

# ===== NAS =====
# Leave blank if you don't use the Synology NAS integration.
NAS_URL=<REPLACE_ME_NAS_URL_OR_EMPTY>
NAS_TOKEN=<REPLACE_ME_NAS_TOKEN_OR_EMPTY>
NAS_VIDEO_ROOT=/volume1/beeeval

# ===== CORS（从其它网站/子域内嵌 H5 调 BeeEVAL API 时必配）=====
# 逗号分隔、无空格；必须含协议、域名，若有非 443/80 端口也要写上。
# 例：CORS_ORIGINS=https://www.example.com,https://app.example.com
CORS_ORIGINS=<REPLACE_ME_OR_EMPTY_FOR_SAME_SITE_ONLY>

# ===== Dr.bee Auto Top-K (auto mode in Lab) =====
# In auto mode, RAG retrieves a pool of RAG_AUTO_POOL candidates and keeps results that
# satisfy: score >= max(RAG_MIN_SCORE_DEFAULT, top1_score * RAG_RELATIVE_RATIO).
# The kept count is clamped to [RAG_MIN_K, RAG_MAX_K]; if fewer than RAG_MIN_K pass the
# filters, the top-K (by score) are kept anyway and the response is flagged low_relevance.
RAG_AUTO_POOL=50
RAG_MIN_SCORE_DEFAULT=0.55
RAG_RELATIVE_RATIO=0.7
RAG_MIN_K=3
RAG_MAX_K=50

# ===== Video local cache + faststart =====
# First time someone watches a NAS video the user still goes through the NAS
# proxy (no slowdown), and we asynchronously download the file and rewrite it
# with `ffmpeg -movflags +faststart` into a local cache. Subsequent viewers
# stream directly from local disk and the moov atom is at the file head, so
# playback starts almost instantly.
#
# Inside Docker the cache lives at /app/video_cache and is backed by a named
# volume (see docker-compose.production.yml `video_cache:`). Keep ENABLED=true
# unless you are short on disk; size is bounded by VIDEO_CACHE_MAX_SIZE_GB and
# evicted LRU.
VIDEO_CACHE_ENABLED=true
VIDEO_CACHE_DIR=/app/video_cache
VIDEO_CACHE_MAX_SIZE_GB=20
VIDEO_CACHE_PER_FILE_MAX_GB=2

# ===== Embedding Model =====
# Path INSIDE the containers (api/worker). Leave as-is.
EMBEDDING_MODEL_PATH=/app/model/bge-base-zh-v1.5

# Path ON THE HOST that is bind-mounted into the containers.
# Must point to a directory containing pytorch_model.bin + tokenizer files
# (BAAI/bge-base-zh-v1.5). Download once with `scripts/download-model.sh`
# or rsync from your dev machine. Relative paths are resolved from the
# folder containing docker-compose.yml.
HOST_MODEL_DIR=./model/bge-base-zh-v1.5
