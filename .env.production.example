# =============================================================
#  BeeEVAL Server .env template (copy to .env.production before deploy)
#
#  !!! Replace every <REPLACE_ME_*> placeholder with a real value. !!!
#  Variables used by docker-compose.production.yml for ${VAR}
#  interpolation MUST be declared at the TOP LEVEL of this file.
# =============================================================

# ===== PostgreSQL =====
DB_HOST=postgres
DB_PORT=5432
DB_NAME=beeeval
DB_USER=postgres
# Strong random string, e.g. `openssl rand -base64 24`
DB_PASSWORD=<REPLACE_ME_DB_PASSWORD>

# ===== Redis =====
# Compose builds REDIS_URL / CELERY_BROKER_URL as redis://:${REDIS_PASSWORD}@redis:6379/0
# so this value MUST be set. Pick another strong random string.
REDIS_PASSWORD=<REPLACE_ME_REDIS_PASSWORD>

# ===== Qdrant =====
# Compose injects QDRANT__SERVICE__API_KEY into the qdrant container.
# API / Worker / local dev clients must pass the same value via QDRANT_API_KEY.
QDRANT_API_KEY=<REPLACE_ME_QDRANT_API_KEY>
QDRANT_COLLECTION=beeeval

# ===== Celery =====
USE_CELERY=true

# ===== LLM =====
LLM_API_KEY=<REPLACE_ME_LLM_API_KEY>
LLM_BASE_URL=https://ai.juguang.chat/v1/chat/completions
LLM_MODEL=<REPLACE_ME_LLM_MODEL>

# ===== NAS =====
# Leave blank if you don't use the Synology NAS integration.
NAS_URL=<REPLACE_ME_NAS_URL_OR_EMPTY>
NAS_TOKEN=<REPLACE_ME_NAS_TOKEN_OR_EMPTY>
NAS_VIDEO_ROOT=/volume1/beeeval

# ===== Embedding Model (inside container path) =====
# Do NOT change unless you also change the Dockerfile COPY target.
EMBEDDING_MODEL_PATH=/app/model/bge-base-zh-v1.5
